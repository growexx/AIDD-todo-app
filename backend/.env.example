PORT=
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=
CLIENT_URL=
FRONTEND_URL=
NODE_ENV=
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
MFA_ENCRYPTION_KEY=3ea092a9aa81c4252dd788647a2cc0a9dc21226b072463a8ce843075cf11bf58

# Email (SMTP). Leave empty to log only (e.g. dev).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# RBAC
API_PREFIX=/api/rbac
DEFAULT_ADMIN_ROLE=super-admin
# Assign super-admin role to these users when running npm run seed:rbac (comma-separated emails)
SEED_SUPER_ADMIN_EMAILS=alice@todoapp.com,bob@todoapp.com

# Demo Auth (development only; must not be true in production)
DEMO_AUTH=false
DEMO_USER_ID=demo-user-001

# Redis (optional — leave unset to disable permission caching)
# REDIS_URL=redis://localhost:6379
# REDIS_CACHE_TTL_SECONDS=300

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
